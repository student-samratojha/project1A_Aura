<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="bg-slate-800 p-4 text-white shadow-md">
        <div class="container mx-auto flex justify-between items-center">
            <span class="font-bold text-xl tracking-wider uppercase">Admin Panel</span>
            <div class="space-x-6">
                <a href="/secure/manageAdmin" class="hover:text-slate-300">Manage All Content</a>
                <a href="/secure/public" class="hover:text-slate-300">View Public Feed</a>
                <a href="/auth/logout" class="bg-red-600 px-4 py-2 rounded hover:bg-red-700 transition">Logout</a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto mt-8 p-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- Pending Users Section -->
            <section class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                <h2 class="text-xl font-bold mb-4 text-yellow-600 border-b pb-2">Pending Verifications</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-gray-500 text-sm uppercase">
                                <th class="py-2">Username</th>
                                <th class="py-2">Email</th>
                                <th class="py-2 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
                            <% pendingUsers.forEach(user => { %>
                            <tr>
                                <td class="py-3 font-medium"><%= user.username %></td>
                                <td class="py-3 text-gray-600"><%= user.email %></td>
                                <td class="py-3 text-right">
                                    <form action="/secure/verify" method="POST" class="inline">
                                        <input type="hidden" name="id" value="<%= user._id %>">
                                        <button type="submit" class="bg-green-500 text-white px-3 py-1 rounded text-sm hover:bg-green-600">Verify</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                            <% if(pendingUsers.length === 0) { %> <tr><td colspan="3" class="py-4 text-center text-gray-400">No pending users</td></tr> <% } %>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Verified Users Section -->
            <section class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                <h2 class="text-xl font-bold mb-4 text-green-600 border-b pb-2">Active Users</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-gray-500 text-sm uppercase">
                                <th class="py-2">Username</th>
                                <th class="py-2">Role</th>
                                <th class="py-2 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
                            <% verifiedUsers.forEach(user => { %>
                            <tr>
                                <td class="py-3 font-medium"><%= user.username %></td>
                                <td class="py-3 text-gray-600"><%= user.role %></td>
                                <td class="py-3 text-right">
                                    <form action="/secure/delete" method="POST" class="inline">
                                        <input type="hidden" name="id" value="<%= user._id %>">
                                        <button type="submit" class="text-red-500 hover:underline text-sm font-bold">Delete</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Audit Logs Section -->
            <section class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 lg:col-span-2">
                <h2 class="text-xl font-bold mb-4 text-blue-600 border-b pb-2">Recent Audit Logs</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="p-3">User</th>
                                <th class="p-3">Action</th>
                                <th class="p-3">IP Address</th>
                                <th class="p-3">Timestamp</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
                            <% auditLogs.forEach(log => { %>
                            <tr class="hover:bg-gray-50">
                                <td class="p-3 font-semibold"><%= log.user ? log.user.username : 'System/Guest' %></td>
                                <td class="p-3"><%= log.action %></td>
                                <td class="p-3 text-gray-500"><%= log.ipAddress %></td>
                                <td class="p-3 text-gray-400">
                                    <%= new Date(log.createdAt).toLocaleString() %>
                                </td>
                            </tr>
                            <% }) %>
                            <% if(auditLogs.length === 0) { %> <tr><td colspan="4" class="p-4 text-center text-gray-400">No logs found</td></tr> <% } %>
                        </tbody>
                    </table>
                </div>
            </section>

        </div>
    </main>
</body>
</html>