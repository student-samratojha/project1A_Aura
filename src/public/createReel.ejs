<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Upload Reel</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 flex items-center justify-center min-h-screen text-white">
    <div class="bg-gray-800 p-8 rounded-2xl shadow-2xl w-full max-w-md m-4 border border-gray-700">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-pink-500 bg-clip-text text-transparent">Create Reel</h2>
            <a href="/secure/user" class="text-gray-400 hover:text-white transition">Cancel</a>
        </div>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-900/50 border border-red-500 text-red-200 p-3 rounded-lg mb-6"><%= error %></div>
        <% } %>

        <form action="/reel/create" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-2">Caption</label>
                <input type="text" name="caption" required class="w-full bg-gray-700 border-none rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-purple-500 outline-none" placeholder="What's the vibe?">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-400 mb-2">Video URL</label>
                <input type="text" name="videoUrl" required class="w-full bg-gray-700 border-none rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-purple-500 outline-none" placeholder="Link to your video file">
            </div>
            <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-600 text-white py-3 rounded-lg font-bold hover:from-purple-500 hover:to-pink-500 transition shadow-lg">
                Share Reel
            </button>
        </form>
    </div>
</body>
</html>