<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Content Management | Aura</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; scroll-behavior: smooth; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .gradient-text { background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .blob { position: absolute; width: 600px; height: 600px; background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(236, 72, 153, 0.1) 100%); filter: blur(100px); border-radius: 50%; z-index: -1; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 overflow-x-hidden min-h-screen">
    <div class="blob top-[-200px] left-[-200px]"></div>
    <div class="blob bottom-[-200px] right-[-200px]"></div>

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 glass border-b border-white/50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/secure/admin" class="text-2xl font-black tracking-tighter gradient-text">Aura</a>
            <div class="flex items-center gap-6">
                <span class="hidden md:inline text-slate-400 text-[10px] font-black uppercase tracking-widest">Global Content Management</span>
                <a href="/secure/admin" class="px-5 py-2 bg-slate-900 text-white font-bold text-xs rounded-xl hover:bg-slate-800 transition shadow-lg shadow-slate-200">← Back to Dashboard</a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-6 py-12">
        <header class="mb-12">
            <h1 class="text-4xl font-black text-slate-900 tracking-tight">System Content Overview</h1>
            <p class="text-slate-500 mt-2 font-medium">Audit and manage all shared media across the platform.</p>
        </header>

        <!-- Post Management Table -->
        <div class="glass rounded-[2.5rem] border border-white/50 shadow-xl shadow-indigo-50 overflow-hidden mb-12">
            <div class="bg-indigo-600/10 px-8 py-4 border-b border-white/50">
                <h2 class="text-sm font-black text-indigo-600 uppercase tracking-widest">User Feed Posts</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-slate-400 text-[10px] font-black uppercase tracking-widest border-b border-slate-100">
                            <th class="px-8 py-4">Author</th>
                            <th class="px-8 py-4">Content Preview</th>
                            <th class="px-8 py-4">Status</th>
                            <th class="px-8 py-4 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% posts.forEach(post => { %>
                        <tr class="hover:bg-white/30 transition <%= post.isDeleted ? 'bg-red-50/30' : '' %>">
                            <td class="px-8 py-4 font-bold text-slate-700"><%= post.user ? post.user.username : 'Unknown' %></td>
                            <td class="px-8 py-4 text-slate-500 text-sm truncate max-w-xs"><%= post.content %></td>
                            <td class="px-8 py-4">
                                <% if(post.isDeleted) { %>
                                    <span class="bg-red-100 text-red-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter">Deleted</span>
                                <% } else { %>
                                    <span class="bg-green-100 text-green-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter">Active</span>
                                <% } %>
                            </td>
                            <td class="px-8 py-4 text-right">
                                <% if(!post.isDeleted) { %>
                                <form action="/secure/deleteContent" method="POST">
                                    <input type="hidden" name="contentType" value="post">
                                    <input type="hidden" name="contentId" value="<%= post._id %>">
                                    <button type="submit" class="text-red-400 hover:text-red-600 font-bold text-xs transition">Remove</button>
                                </form>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                        <% if(posts.length === 0) { %> <tr><td colspan="4" class="py-10 text-center text-slate-300 italic">No posts found</td></tr> <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Stories & Reels Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-12">
             <div class="glass rounded-[2rem] border border-white/50 p-8 shadow-lg">
                <h3 class="text-lg font-black mb-6 text-amber-600 flex items-center gap-2 uppercase tracking-widest text-xs">
                    <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                    Total Stories: <%= storys.length %>
                </h3>
                <div class="space-y-2">
                    <% storys.slice(0, 5).forEach(story => { %>
                        <div class="flex justify-between text-sm border-b border-slate-100 pb-2">
                            <span class="font-bold text-slate-700"><%= story.user ? story.user.username : 'User' %></span>
                            <span class="text-slate-400 italic truncate ml-4"><%= story.content.substring(0, 30) %>...</span>
                        </div>
                    <% }) %>
                </div>
             </div>
             <div class="glass rounded-[2rem] border border-white/50 p-8 shadow-lg">
                <h3 class="text-lg font-black mb-6 text-purple-600 flex items-center gap-2 uppercase tracking-widest text-xs">
                    <span class="w-2 h-2 rounded-full bg-purple-500"></span>
                    Total Reels: <%= reels.length %>
                </h3>
                <div class="space-y-2">
                    <% reels.slice(0, 5).forEach(reel => { %>
                        <div class="flex justify-between text-sm border-b border-slate-100 pb-2">
                            <span class="font-bold text-slate-700"><%= reel.user ? reel.user.username : 'User' %></span>
                            <span class="text-slate-400 italic truncate ml-4"><%= reel.content.substring(0, 30) %>...</span>
                        </div>
                    <% }) %>
                </div>
             </div>
        </div>

        <!-- Engagement Summary -->
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
            <h2 class="text-xl font-bold mb-6">Interaction Logs Overview</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
                <div class="p-4 bg-indigo-50 rounded-lg">
                    <span class="block text-2xl font-bold text-indigo-600"><%= comments.length %></span>
                    <span class="text-gray-500 text-xs uppercase">Comments</span>
                </div>
                <div class="p-4 bg-pink-50 rounded-lg">
                    <span class="block text-2xl font-bold text-pink-600"><%= likes.length %></span>
                    <span class="text-gray-500 text-xs uppercase">Total Likes</span>
                </div>
                <div class="p-4 bg-green-50 rounded-lg">
                    <span class="block text-2xl font-bold text-green-600"><%= posts.filter(p => !p.isDeleted).length %></span>
                    <span class="text-gray-500 text-xs uppercase">Active Posts</span>
                </div>
                <div class="p-4 bg-slate-50 rounded-lg">
                    <span class="block text-2xl font-bold text-slate-600"><%= storys.length + reels.length %></span>
                    <span class="text-gray-500 text-xs uppercase">Media Items</span>
                </div>
            </div>
        </div>

    </main>
</body>
</html>