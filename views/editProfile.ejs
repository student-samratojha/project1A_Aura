<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | Aura</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; scroll-behavior: smooth; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .gradient-text { background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .blob { position: absolute; width: 600px; height: 600px; background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(236, 72, 153, 0.1) 100%); filter: blur(100px); border-radius: 50%; z-index: -1; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 overflow-x-hidden min-h-screen flex flex-col">
    <div class="blob top-[-200px] left-[-200px]"></div>
    <div class="blob bottom-[-200px] right-[-200px]"></div>

    <nav class="sticky top-0 z-50 glass border-b border-white/50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-tighter gradient-text">Aura</a>
            <a href="/secure/user" class="text-slate-500 font-bold text-sm hover:text-indigo-600 transition">← Back to Dashboard</a>
        </div>
    </nav>

    <main class="flex-grow flex items-center justify-center p-6 py-12">
        <div class="glass max-w-lg w-full p-10 rounded-[2.5rem] shadow-2xl border border-white/50">
            <h2 class="text-3xl font-black text-slate-900 tracking-tight mb-8">Edit <span class="gradient-text">Profile.</span></h2>
            
            <form action="/secure/editProfile" method="POST" class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Username</label>
                    <input type="text" name="username" value="<%= user.username %>" class="w-full px-5 py-3 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white/50">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Email</label>
                    <input type="email" name="email" value="<%= user.email %>" class="w-full px-5 py-3 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white/50">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Profile Bio</label>
                    <textarea name="bio" class="w-full px-5 py-3 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none h-28 resize-none bg-white/50"><%= user.bio %></textarea>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Profile Picture URL</label>
                    <input type="text" name="profilePic" value="<%= user.profilePic %>" class="w-full px-5 py-3 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white/50">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">New Password (Optional)</label>
                    <input type="password" name="password" placeholder="Leave blank to keep current" class="w-full px-5 py-3 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white/50">
                </div>
                <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-2xl font-bold hover:bg-slate-800 transition shadow-xl transform active:scale-[0.98]">
                    Update Profile
                </button>
            </form>

            <div class="mt-12 pt-8 border-t border-red-50">
                <h3 class="text-red-500 font-black text-xs uppercase tracking-widest mb-2 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                    Danger Zone
                </h3>
                <p class="text-[11px] text-slate-400 mb-5 font-medium">Deleting your account is permanent. All your content will be hidden immediately.</p>
                <form action="/secure/deleteAccount" method="POST">
                    <button type="submit" onclick="return confirm('Are you sure?')" class="w-full py-3 border-2 border-red-100 text-red-500 font-bold rounded-2xl hover:bg-red-50 hover:border-red-200 transition text-sm">
                        Delete My Account
                    </button>
                </form>
            </div>
        </div>
    </main>
</body>
</html>