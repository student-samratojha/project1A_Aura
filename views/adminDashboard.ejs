<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Aura</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; scroll-behavior: smooth; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .gradient-text { background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .blob { position: absolute; width: 600px; height: 600px; background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(236, 72, 153, 0.1) 100%); filter: blur(100px); border-radius: 50%; z-index: -1; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 overflow-x-hidden min-h-screen">
    <div class="blob top-[-200px] left-[-200px]"></div>
    <div class="blob bottom-[-200px] right-[-200px]"></div>

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 glass border-b border-white/50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-tighter gradient-text">Aura</a>
            <div class="hidden md:flex space-x-8 font-bold text-slate-500 uppercase text-[10px] tracking-widest">
                <a href="/secure/manageAdmin" class="hover:text-indigo-600 transition">Manage Content</a>
            </div>
            <div class="flex items-center gap-4">
                <a href="/auth/logout" class="px-5 py-2 bg-red-50 text-red-600 font-bold text-sm rounded-xl hover:bg-red-100 transition">Logout</a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-6 py-12">
        <!-- Admin Profile Card -->
        <div class="glass p-8 rounded-[2.5rem] mb-12 flex flex-col md:flex-row items-center justify-between gap-6 border border-white/50 shadow-xl shadow-indigo-50">
            <div class="flex items-center gap-6">
                <div class="w-24 h-24 bg-gradient-to-br overflow-hidden from-indigo-500 to-purple-600 rounded-[1.5rem] flex items-center justify-center text-white text-3xl font-black shadow-lg">
                    <img src="<%=user.profilePic%>" clas="w-full object-cover rounded-[1.5rem]">
                </div>
                <div>
                    <h2 class="text-2xl font-black text-slate-900 tracking-tight"><%= user.username %></h2>
                    <p class="text-slate-500 font-medium text-sm"><%= user.email %></p>
                    <p class="text-slate-500 font-medium text-sm"><%= user.bio || 'No bio' %></p>
                    <span class="inline-block mt-2 px-3 py-1 bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-full border border-indigo-100">
                        System <%= user.role %>
                    </span>

                </div>
            </div>
            <a href="/secure/editProfile" class="px-8 py-4 bg-slate-900 text-white font-bold rounded-2xl hover:bg-slate-800 transition transform hover:-translate-y-1 shadow-xl shadow-slate-200">
                Edit Profile Settings
            </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            
            <!-- Pending Users Section -->
            <section class="glass p-8 rounded-[2rem] border border-white/50 shadow-lg">
                <h2 class="text-xl font-black mb-6 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span>
                    Pending Verifications
                </h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-slate-400 text-[10px] font-black uppercase tracking-widest border-b border-slate-100">
                                <th class="pb-4">Username</th>
                                <th class="pb-4">Email</th>
                                <th class="pb-4 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% pendingUsers.forEach(user => { %>
                            <tr class="group">
                                <td class="py-4 font-bold text-slate-700"><%= user.username %></td>
                                <td class="py-4 text-slate-500 text-sm"><%= user.email %></td>
                                <td class="py-4 text-right">
                                    <form action="/secure/verify" method="POST" class="inline">
                                        <input type="hidden" name="id" value="<%= user._id %>">
                                        <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded-xl text-xs font-bold hover:bg-indigo-700 transition transform group-hover:scale-105">Verify</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                            <% if(pendingUsers.length === 0) { %> <tr><td colspan="3" class="py-10 text-center text-slate-400 text-sm italic">Workspace is clear</td></tr> <% } %>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Verified Users Section -->
            <section class="glass p-8 rounded-[2rem] border border-white/50 shadow-lg">
                <h2 class="text-xl font-black mb-6 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-green-500"></span>
                    Active Community
                </h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-slate-400 text-[10px] font-black uppercase tracking-widest border-b border-slate-100">
                                <th class="pb-4">Username</th>
                                <th class="pb-4">Email</th>
                                <th class="pb-4 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% if(verifiedUsers.length > 0) { %> 
                            <% verifiedUsers.forEach(user => { %>
                            <tr>
                                <td class="py-4 font-bold text-slate-700"><%= user.username %></td>
                                <td class="py-4">
                                    <span class="text-[10px] font-bold px-2 py-1 rounded-md bg-slate-100 text-slate-500 uppercase tracking-tighter"><%= user.email%></span>
                                </td>
                                <td class="py-4 text-right">
                                    <form action="/secure/delete" method="POST" class="inline">
                                        <input type="hidden" name="id" value="<%= user._id %>">
                                        <button type="submit" class="text-red-400 hover:text-red-600 transition text-xs font-bold">Restrict</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                            <%} else{%>
                                <tr><td colspan="3" class="py-10 text-center text-slate-400 text-sm italic">Workspace is clear</td></tr> <% } %>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Audit Logs Section -->
            <section class="glass p-8 rounded-[2rem] border border-white/50 shadow-lg lg:col-span-2">
                <h2 class="text-xl font-black mb-6">System Transparency Logs</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead>
                            <tr class="text-slate-400 text-[10px] font-black uppercase tracking-widest border-b border-slate-100">
                                <th class="pb-4">Admin/User</th>
                                <th class="pb-4">Event</th>
                                <th class="pb-4">Network IP</th>
                                <th class="pb-4">Timestamp</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% auditLogs.forEach(log => { %>
                            <tr class="hover:bg-white/30 transition">
                                <td class="py-4 font-bold text-slate-700">
                                    <%= log.user ? log.user.username : 'System Core' %>
                                </td>
                                <td class="py-4 text-slate-600 italic font-medium">"<%= log.action %>"</td>
                                <td class="py-4 text-slate-400 font-mono text-xs"><%= log.ip %></td>
                                <td class="py-4 text-slate-400 text-xs">
                                    <%= new Date(log.createdAt).toLocaleString() %>
                                </td>
                            </tr>
                            <% }) %>
                            <% if(auditLogs.length === 0) { %> <tr><td colspan="4" class="py-10 text-center text-slate-300">No records found.</td></tr> <% } %>
                        </tbody>
                    </table>
                </div>
            </section>

        </div>
    </main>
</body>
</html>